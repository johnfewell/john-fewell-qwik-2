---
import Layout from '~/layouts/Layout.astro';
import LucidHeader from '~/components/widgets/LucidHeader.astro';

export interface Props {
  title?: string;
  description?: string;
  active?: 'work' | 'about' | 'blog';
}

const { title, description, active } = Astro.props;
---

<Layout title={title} description={description} noHeader>
  <div class="lucid-surface" data-lucid-rest="0.68,0.35">
    <div class="lucid-overlay"></div>
    <canvas class="lucid-petals" aria-hidden="true" transition:persist="lucid-petals"></canvas>
    <div class="lucid-content">
      <LucidHeader active={active} />
      <slot />
    </div>
    <canvas class="lucid-petals-front" aria-hidden="true" transition:persist="lucid-petals-front"></canvas>
  </div>
</Layout>

<style is:global>
  body {
    background-color: #d9a983;
  }
  .dark body {
    background-color: rgb(4 4 18);
  }
</style>

<script>
  import { startLucidPetals } from '~/components/common/lucidPetals';

  // With the ClientRouter, navigations swap the DOM in place rather than doing a
  // full reload, so this module executes only once. Setup is therefore wired to
  // astro:page-load (fires on the first load and after every navigation), and the
  // petal canvases carry transition:persist so the blossoms drift on unbroken
  // instead of resetting on each page change.

  let wanderStarted = false;

  // One self-perpetuating loop drives the overlay's light spot. It re-queries the
  // surface every frame so it keeps targeting the live element after a page swap,
  // and a guard ensures it is only ever started once.
  const startWander = () => {
    if (wanderStarted || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    wanderStarted = true;
    const tick = () => {
      const surface = document.querySelector<HTMLElement>('.lucid-surface');
      if (surface) {
        const [rx, ry] = (surface.dataset.lucidRest || '0.5,0.5').split(',').map(Number);
        const t = performance.now() / 1000;
        // Slow autonomous wander: two superimposed sine drifts, ~2-minute periods.
        const x = (rx + 0.16 * Math.sin(t * 0.052) + 0.09 * Math.sin(t * 0.029)) * surface.clientWidth;
        const y = (ry + 0.13 * Math.sin(t * 0.041) + 0.08 * Math.cos(t * 0.026)) * surface.clientHeight;
        surface.style.setProperty('--mx', x.toFixed(1) + 'px');
        surface.style.setProperty('--my', y.toFixed(1) + 'px');
      }
      requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  };

  const initLucid = () => {
    const petalCanvas = document.querySelector<HTMLCanvasElement>('.lucid-petals');
    const petalFront = document.querySelector<HTMLCanvasElement>('.lucid-petals-front');
    // A persisted canvas carries its running animation across navigations, and the
    // flag rides along with the node — so we never start a second loop on it. A
    // genuinely new canvas (e.g. returning from a non-lucid page like 404) has no
    // flag and gets started fresh.
    if (petalCanvas && !petalCanvas.dataset.petalsRunning) {
      petalCanvas.dataset.petalsRunning = 'true';
      startLucidPetals(petalCanvas, petalFront);
    }
    startWander();
  };

  document.addEventListener('astro:page-load', initLucid);
</script>
