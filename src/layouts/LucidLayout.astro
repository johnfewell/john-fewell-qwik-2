---
import Layout from '~/layouts/Layout.astro';
import LucidHeader from '~/components/widgets/LucidHeader.astro';

export interface Props {
  title?: string;
  description?: string;
  active?: 'work' | 'about';
}

const { title, description, active } = Astro.props;
---

<Layout title={title} description={description} noHeader>
  <div class="lucid-surface" data-lucid-rest="0.68,0.35">
    <div class="lucid-overlay"></div>
    <canvas class="lucid-petals" aria-hidden="true"></canvas>
    <div class="lucid-content">
      <LucidHeader active={active} />
      <slot />
    </div>
  </div>
</Layout>

<style is:global>
  body {
    background-color: #d9a983;
  }
  .dark body {
    background-color: rgb(4 4 18);
  }
</style>

<script>
  import { startLucidPetals } from '~/components/common/lucidPetals';

  const petalCanvas = document.querySelector<HTMLCanvasElement>('.lucid-petals');
  if (petalCanvas) startLucidPetals(petalCanvas);

  const surface = document.querySelector<HTMLElement>('.lucid-surface');
  if (surface && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const [rx, ry] = (surface.dataset.lucidRest || '0.5,0.5').split(',').map(Number);
    const tick = () => {
      const t = performance.now() / 1000;
      // Slow autonomous wander: two superimposed sine drifts, ~2-minute periods.
      const x = (rx + 0.16 * Math.sin(t * 0.052) + 0.09 * Math.sin(t * 0.029)) * surface.clientWidth;
      const y = (ry + 0.13 * Math.sin(t * 0.041) + 0.08 * Math.cos(t * 0.026)) * surface.clientHeight;
      surface.style.setProperty('--mx', x.toFixed(1) + 'px');
      surface.style.setProperty('--my', y.toFixed(1) + 'px');
      requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  }
</script>
