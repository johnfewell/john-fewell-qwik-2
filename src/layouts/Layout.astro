---
import '~/assets/styles/global.css';
import '~/assets/styles/prism.css';

import { ClientRouter } from 'astro:transitions';

import Header from '~/components/widgets/Header';
import { SITE } from '~/config.mjs';

export interface Props {
  title?: string;
  description?: string;
  noHeader?: boolean;
}

const { title = SITE.title, description = SITE.description, noHeader = false } = Astro.props;
const canonical = new URL(Astro.url.pathname, SITE.origin);
---

<!doctype html>
<html lang="en">
  <head>
    <script
      is:inline
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "8b78ef5c9b154436b6b8795a026af97c"}'></script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="manifest" href="/manifest.json" />
    <title>{title}</title>
    <link rel="canonical" href={String(canonical)} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <ClientRouter />
    <script is:inline>
      const applyTheme = () => {
        const stored = localStorage.theme;
        const dark =
          stored === 'dark' ||
          (typeof stored === 'undefined' && window.matchMedia('(prefers-color-scheme: dark)').matches);
        document.documentElement.classList.toggle('dark', dark);
      };
      applyTheme();
      // The ClientRouter resets <html>'s attributes to the server-rendered
      // version on each swap (which carries no dark class), so re-apply the
      // theme before the new page paints to avoid flipping to light.
      document.addEventListener('astro:after-swap', applyTheme);
    </script>
  </head>
  <body
    class="text-gray-900 dark:text-slate-300 tracking-tight bg-white dark:bg-gray-900 antialiased"
  >
    {!noHeader && <Header client:load />}
    <main>
      <slot />
    </main>
    <script>
      import { startConsoleLurker } from '~/components/common/consoleLurker';
      startConsoleLurker();
    </script>
  </body>
</html>
