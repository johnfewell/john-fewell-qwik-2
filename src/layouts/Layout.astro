---
import '~/assets/styles/global.css';
import '~/assets/styles/prism.css';

import Header from '~/components/widgets/Header';
import { SITE } from '~/config.mjs';

export interface Props {
  title?: string;
  description?: string;
}

const { title = SITE.title, description = SITE.description } = Astro.props;
const canonical = new URL(Astro.url.pathname, SITE.origin);
---

<!doctype html>
<html lang="en">
  <head>
    <script
      is:inline
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "8b78ef5c9b154436b6b8795a026af97c"}'></script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="manifest" href="/manifest.json" />
    <title>{title}</title>
    <link rel="canonical" href={String(canonical)} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <script is:inline>
      if (localStorage.theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else if (typeof localStorage.theme === 'undefined') {
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          document.documentElement.classList.add('dark');
        }
      }
    </script>
  </head>
  <body
    class="text-gray-900 dark:text-slate-300 tracking-tight bg-white dark:bg-gray-900 antialiased"
  >
    <Header client:load />
    <main>
      <slot />
    </main>
  </body>
</html>
