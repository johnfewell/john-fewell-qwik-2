---
export interface Props {
  active?: 'work' | 'about';
}

const { active } = Astro.props;
---

<div class="flex justify-between items-center h-[72px] px-5 sm:px-12 flex-none">
  <a href="/" class="flex items-center no-underline">
    <img src="/images/blob-logo.svg" width={32} height={32} alt="John Fewell logo" />
    <span class="eyebrow ml-1.5">JF</span>
  </a>
  <div class="flex items-center gap-[18px] sm:gap-[34px]">
    <a class="lucid-nav-link" href="/work/" data-active={active === 'work' ? true : undefined}>Work</a>
    <a class="lucid-nav-link" href="/about/" data-active={active === 'about' ? true : undefined}>About</a>
    <a class="lucid-nav-link" href="/blog/">Blog</a>
    <a class="lucid-nav-link" href="mailto:fewell@gmail.com">Contact</a>
    <button id="lucid-theme-toggle" class="lucid-toggle" aria-label="Toggle day / night">
      <svg
        class="icon-sun"
        width="22"
        height="22"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><circle cx="12" cy="12" r="4"></circle><path
          d="M3 12h1m8 -9v1m8 8h1m-9 8v1m-6.4 -15.4l.7 .7m12.1 -.7l-.7 .7m0 11.4l.7 .7m-12.1 -.7l-.7 .7"></path></svg
      >
      <svg
        class="icon-moon"
        width="22"
        height="22"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M12 3c.132 0 .263 0 .393 0a7.5 7.5 0 0 0 7.92 12.446a9 9 0 1 1 -8.313 -12.454z"></path></svg
      >
    </button>
  </div>
</div>

<script>
  document.getElementById('lucid-theme-toggle')?.addEventListener('click', () => {
    const dark = document.documentElement.classList.toggle('dark');
    window.localStorage.theme = dark ? 'dark' : 'light';
  });
</script>
