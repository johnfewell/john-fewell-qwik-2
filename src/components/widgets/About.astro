---
import face from '~/assets/images/home-computer.webp';
---

<section class="relative flex-1 flex flex-col justify-center px-5 sm:px-12 py-10 min-h-0">
  <img
    src={face.src}
    width={480}
    height={480}
    alt=""
    loading="lazy"
    class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[clamp(320px,42vw,560px)] opacity-[0.1] pointer-events-none select-none"
  />

  <div
    class="relative grid items-start gap-y-10 lg:gap-y-0 lg:grid-cols-[0.85fr_1.15fr]"
    style="column-gap: clamp(40px, 7vw, 112px)"
  >
    <!-- Anchor: display word + lede -->
    <div class="flex flex-col gap-6 lg:gap-7">
      <div class="overflow-hidden">
        <h1
          class="display-text leading-[0.85] moveup-text"
          style="font-size: clamp(72px, 11vw, 148px); letter-spacing: 0.04em"
        >
          About
        </h1>
      </div>
      <p
        class="m-0 max-w-[22ch]"
        style="font-family: 'fits', serif; font-weight: 400; color: var(--text-display); font-size: clamp(20px, 2.4vw, 28px); line-height: 1.35; letter-spacing: 0.005em"
      >
        I'm John — a senior full-stack engineer building agentic systems and production web apps.
      </p>
    </div>

    <!-- Reading column: bio + skills -->
    <div class="flex flex-col gap-8 max-w-[56ch]">
      <div class="flex flex-col gap-4">
        <p class="text-[15px] leading-[1.65] m-0 text-pretty" style="color: var(--text-body)">
          I build LLM-driven tools, modern front ends, and the glue between them: LangGraph workflows, constrained action
          spaces, typed state surfaces, eval infrastructure, and production Angular/React applications.
        </p>
        <p class="text-[15px] leading-[1.65] m-0 text-pretty" style="color: var(--text-body)">
          Most recently at Rohirrim AI, I built a LangGraph-based test-failure triage agent, delivered most of a NextGen
          frontend prototype, migrated document processing from NestJS to FastAPI with Docling, and owned Angular
          framework upgrades through v20.
        </p>
      </div>
      <div class="flex flex-col gap-2">
        <div class="eyebrow-sm">Skills</div>
        <div class="text-sm leading-[1.7]" style="color: var(--text-body)">
          LLM Agents / LangGraph / TypeScript / Angular 4–20 / React / Python / FastAPI / Node.js / NgRx SignalStore /
          TanStack Query / RxJS / Playwright / Docker / AWS / REST APIs
        </div>
      </div>
    </div>

    <!-- CTAs: anchored bottom-left, span full width so mobile order stays About → bio → actions -->
    <div class="flex flex-wrap gap-4 mt-2 lg:mt-14 lg:col-span-2">
      <a class="fancy-button" href="/files/John_Fewell-Resume.pdf" target="_blank" rel="noreferrer"> Resume </a>
      <a class="fancy-button" href="mailto:fewell@gmail.com"> Contact </a>
    </div>
  </div>
</section>
