---
---

<!-- HERO -->
<section class="flex flex-col px-5 sm:px-12 pb-12 min-h-[calc(100svh-72px)]">
  <div class="flex-1 flex items-center justify-center overflow-hidden">
    <h1
      class="display-text tracking-wider leading-none moveup-text text-center"
      style="font-size: clamp(64px, 13vw, 210px)"
    >
      CONTACT
    </h1>
  </div>
  <div class="overflow-hidden">
    <p class="moveup-text m-0 text-[15px] leading-[1.6] max-w-[340px]" style="color: var(--text-body)">
      Got a role, a project, or an agent-systems problem worth talking through? Drop me a line.
    </p>
  </div>
</section>

<!-- CONTENT -->
<div class="px-5 sm:px-12 pt-24 pb-[110px]">
  <div class="grid gap-12 lg:gap-[72px] lg:grid-cols-2 items-start">
    <!-- LEFT: intro -->
    <div>
      <div class="eyebrow-sm mb-[18px]">Contact</div>
      <h2 class="display-text moveup-text" style="font-size: clamp(44px, 6vw, 84px); line-height: 1.05">
        Let's build something
      </h2>
      <p class="text-base leading-[1.7] max-w-[460px] mt-6 m-0" style="color: var(--text-body)">
        Open to senior and staff IC roles, fully remote, and always glad to talk about agent systems, AI-native
        developer tools, or anything where the LLM meaningfully drives the app.
      </p>
      <div class="mt-10">
        <div class="eyebrow-sm mb-[10px]">Email</div>
        <a
          href="mailto:fewell@gmail.com"
          class="text-base underline"
          style="color: var(--text-display); text-underline-offset: 3px">fewell@gmail.com</a
        >
      </div>
    </div>

    <!-- RIGHT: form -->
    <form id="lucid-contact-form" class="flex flex-col gap-7">
      <!-- Web3Forms routing key (public-safe; only maps to the destination inbox)
           and a static subject line for the notification email. -->
      <input type="hidden" name="access_key" value="a4a0d949-0c71-4e4d-b7e3-755bd70cb510" />
      <input type="hidden" name="subject" value="New message from johnfewell.com" />
      <input type="hidden" name="from_name" value="johnfewell.com contact form" />
      <!-- Honeypot: bots fill every field; humans never see this. A checked value
           makes Web3Forms silently drop the submission as spam. -->
      <input type="checkbox" name="botcheck" class="hidden" style="display: none" tabindex="-1" autocomplete="off" />

      <div class="flex flex-col gap-[10px]">
        <label class="lucid-label" for="cf-name">Name</label>
        <input class="lucid-field" id="cf-name" name="name" type="text" required />
      </div>
      <div class="flex flex-col gap-[10px]">
        <label class="lucid-label" for="cf-email">Email</label>
        <input class="lucid-field" id="cf-email" name="email" type="email" required />
      </div>
      <div class="flex flex-col gap-[10px]">
        <label class="lucid-label" for="cf-message">Message</label>
        <textarea class="lucid-field resize-y" id="cf-message" name="message" rows="6" required></textarea>
      </div>
      <div class="flex items-center gap-4">
        <button class="lucid-cta" type="submit">Send message</button>
        <p
          id="cf-status"
          role="status"
          aria-live="polite"
          class="m-0 text-[15px]"
          style="color: var(--text-body)"
        >
        </p>
      </div>
    </form>
  </div>
</div>

<script>
  // Bind on astro:page-load (fires on first load AND after every ClientRouter
  // navigation) rather than at module-execution time. A component's module
  // script isn't reliably re-run on SPA navigations, so binding once at import
  // time would leave the form dead when reaching /contact via an in-app nav click.
  // Each navigation swaps in a fresh form node, so we bind straight to it and
  // mark it to avoid double-binding if the event fires twice for one node.
  const initContactForm = () => {
    const form = document.getElementById('lucid-contact-form');
    if (!(form instanceof HTMLFormElement) || form.dataset.bound) return;
    form.dataset.bound = 'true';

    const status = document.getElementById('cf-status');
    const button = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    const setStatus = (msg: string) => {
      if (status) status.textContent = msg;
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (button) button.disabled = true;
      setStatus('Sending…');

      try {
        const response = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: new FormData(form),
        });
        const data = await response.json();

        if (data.success) {
          form.reset();
          setStatus('Thanks, your message is on its way.');
        } else {
          setStatus(data.message || 'Something went wrong. Please email me directly.');
        }
      } catch {
        setStatus('Network error. Please email me directly.');
      } finally {
        if (button) button.disabled = false;
      }
    });
  };

  document.addEventListener('astro:page-load', initContactForm);
</script>
