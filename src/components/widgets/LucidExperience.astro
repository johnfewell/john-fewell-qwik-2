---
const history = [
  { company: 'Rohirrim', role: 'Senior Full-Stack Developer', period: '2025 – PRESENT' },
  { company: '3Pillar Global', role: 'Senior Software Engineer', period: '2023 – 2025' },
  { company: 'Ratio.City — Esri Canada', role: 'Senior Frontend Developer', period: '2020 – 2021' },
  { company: 'Freelance', role: 'Web Developer', period: '2018 – 2023' },
];
---

<div class="lucid-section grid gap-8 md:gap-12 md:grid-cols-[230px_1fr] items-start pt-12">
  <div class="eyebrow-sm">Where I've been</div>
  <div>
    {
      history.map((job) => (
        <div
          class="lucid-section flex justify-between items-baseline gap-6 py-[18px]"
          style="border-top: none; border-bottom: 1px solid var(--lucid-rule)"
        >
          <div class="flex items-baseline gap-4 flex-wrap">
            <span class="lucid-subhead" style="font-size: clamp(26px, 2.4vw, 34px); line-height: 1">
              {job.company}
            </span>
            <span class="text-sm" style="color: var(--text-muted)">
              {job.role}
            </span>
          </div>
          <div
            class="lucid-subhead whitespace-nowrap"
            style="font-size: clamp(17px, 1.6vw, 23px); letter-spacing: 0.16em"
          >
            {job.period}
          </div>
        </div>
      ))
    }
  </div>
</div>
