{
  "name": "john-fewell-astro",
  "description": "Personal site of John Fewell, built with Astro + React + Tailwind CSS.",
  "version": "0.119.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev --open",
    "build": "astro build && jampack ./dist",
    "preview": "astro preview --open",
    "build.types": "astro check",
    "fmt": "prettier --write .",
    "fmt.check": "prettier --check ."
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "dependencies": {
    "@astrojs/react": "^4.4.2",
    "@astrojs/tailwind": "^6.0.2",
    "@tailwindcss/typography": "^0.5.20",
    "astro": "^5.18.2",
    "markdown-it": "^14.2.0",
    "markdown-it-prism": "^3.0.1",
    "prismjs": "^1.30.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.1",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@divriots/jampack": "^0.34.1",
    "@types/markdown-it": "^14.1.2",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "prettier": "^3.8.4",
    "typescript": "^5.9.3"
  }
}
